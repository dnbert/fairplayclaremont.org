---
const boysFields = [
  { name: 'Field 1', park: 'College Park', lights: true,  fence: true,  lock: true },
  { name: 'Field 2', park: 'College Park', lights: true,  fence: true,  lock: true },
  { name: 'Field 3', park: 'College Park', lights: false, fence: true,  lock: true },
];

const girlsFields = [
  { name: 'Field 1', park: 'La Puerta Park', lights: true,  fence: false, lock: false },
  { name: 'Field 2', park: 'La Puerta Park', lights: false, fence: false, lock: false },
  { name: 'Field 1', park: 'Wheeler Park',   lights: false, fence: true,  lock: false },
];

const tableRows = [
  {
    label: 'Players served',
    boys: { text: 'Claremont youth', positive: true, note: null },
    girls: { text: 'Claremont youth', positive: true, note: null },
  },
  {
    label: 'Number of fields',
    boys: { text: '3', positive: true, note: null },
    girls: { text: '3', positive: true, note: null },
  },
  {
    label: 'All fields at one park',
    boys: { text: 'Yes', positive: true, note: 'College Park' },
    girls: { text: 'No', positive: false, note: 'La Puerta + Wheeler' },
  },
  {
    label: 'Fields with lights',
    boys: { text: '2 of 3', positive: true, note: null },
    girls: { text: '1 of 3', positive: false, note: null },
  },
  {
    label: 'Fields with fencing',
    boys: { text: 'All 3', positive: true, note: null },
    girls: { text: '1 of 3', positive: false, note: null },
  },
  {
    label: 'Fields with lights AND fence',
    boys: { text: '2 of 3', positive: true, note: null },
    girls: { text: '0 of 3', positive: false, note: null },
  },
  {
    label: 'Lockable fields',
    boys: { text: 'All 3', positive: true, note: null },
    girls: { text: 'None', positive: false, note: null },
  },
  {
    label: 'Sunday access',
    boys: { text: 'Unlimited', positive: true, note: null },
    girls: { text: '4 days per year', positive: false, note: 'La Puerta, capped by Ordinance 11.08' },
  },
];
---

<section id="inequity" class="py-16 md:py-20 px-6 scroll-mt-16">
  <div class="max-w-6xl mx-auto">

    <p class="text-xs font-semibold tracking-widest uppercase text-gray-600 mb-2">The inequity</p>
    <h2 class="font-display text-2xl md:text-3xl font-semibold text-gray-900 mb-3">
      College Park vs. La Puerta &amp; Wheeler — field by field
    </h2>
    <p class="text-gray-700 text-base md:text-lg leading-relaxed max-w-2xl mb-10">
      Both programs have 3 fields and serve Claremont youth. But boys baseball operates out
      of a single fully equipped complex at College Park. Girls fastpitch is split across two
      parks with no field that has lights, a fence, <em>and</em> a lock.
    </p>

    <!-- Field cards -->
    <div class="grid md:grid-cols-2 gap-4 mb-12">

      <!-- Boys -->
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <div class="flex items-center justify-between bg-boys-bg text-boys-text text-xs font-semibold px-3 py-2">
          <span>Boys baseball &nbsp;·&nbsp; ~300 players</span>
          <span>College Park</span>
        </div>
        <div class="divide-y divide-gray-100">
          {boysFields.map(f => (
            <div class="flex items-center gap-3 px-4 py-3 bg-white">
              <span class="text-sm font-medium text-gray-800 flex-1">
                {f.name}
                <span class="text-xs font-normal text-gray-600 ml-1">{f.park}</span>
              </span>
              <div class="flex gap-1.5 flex-wrap justify-end">
                {f.lights
                  ? <span class="tag-yes">Lights</span>
                  : <span class="tag-neutral">No lights</span>}
                {f.fence
                  ? <span class="tag-yes">Fenced</span>
                  : <span class="tag-no">No fence</span>}
                {f.lock
                  ? <span class="tag-yes">Lockable</span>
                  : <span class="tag-no">No lock</span>}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Girls -->
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <div class="flex items-center justify-between bg-girls-bg text-girls-text text-xs font-semibold px-3 py-2">
          <span>Girls softball &nbsp;·&nbsp; ~150 players</span>
          <span>2 parks</span>
        </div>
        <div class="divide-y divide-gray-100">
          {girlsFields.map(f => (
            <div class="flex items-center gap-3 px-4 py-3 bg-white">
              <span class="text-sm font-medium text-gray-800 flex-1">
                {f.name}
                <span class="text-xs font-normal text-gray-600 ml-1">{f.park}</span>
              </span>
              <div class="flex gap-1.5 flex-wrap justify-end">
                {f.lights
                  ? <span class="tag-yes">Lights</span>
                  : <span class="tag-neutral">No lights</span>}
                {f.fence
                  ? <span class="tag-yes">Fenced</span>
                  : <span class="tag-neutral">No fence</span>}
                {f.lock
                  ? <span class="tag-yes">Lockable</span>
                  : <span class="tag-neutral">No lock</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Comparison table -->
    <div class="overflow-x-auto rounded-lg bg-white border border-gray-200" tabindex="0" role="region" aria-label="Field access comparison, scrollable">
      <table class="w-full text-sm md:text-base border-collapse">
        <caption class="sr-only">
          Program access for boys baseball at College Park compared with girls softball
          at La Puerta and Wheeler parks, row by row.
        </caption>
        <thead>
          <tr class="border-b border-gray-100">
            <th scope="col" class="text-left text-xs font-semibold text-gray-600 bg-gray-100 px-3 py-2 w-2/5">Program access</th>
            <th scope="col" class="text-center text-xs font-semibold text-boys-text bg-boys-bg px-3 py-2 w-[30%]">Boys baseball</th>
            <th scope="col" class="text-center text-xs font-semibold text-girls-text bg-girls-bg px-3 py-2 w-[30%]">Girls softball</th>
          </tr>
        </thead>
        <tbody>
          {tableRows.map(row => (
            <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50">
              <th scope="row" class="text-left font-normal px-4 py-3 text-gray-800">
                {row.label}
              </th>
              <td class="px-4 py-3 text-center bg-boys-bg/30">
                <span class={`${row.boys.positive ? 'text-yes-text font-medium' : 'text-no-text font-medium'}`}>
                  <span aria-hidden="true">{row.boys.positive ? '✓ ' : '✗ '}</span>{row.boys.text}
                </span>
                {row.boys.note && (
                  <span class="block text-xs text-gray-600 mt-0.5">{row.boys.note}</span>
                )}
              </td>
              <td class="px-4 py-3 text-center bg-girls-bg/30">
                <span class={`${row.girls.positive ? 'text-yes-text font-medium' : 'text-no-text font-medium'}`}>
                  <span aria-hidden="true">{row.girls.positive ? '✓ ' : '✗ '}</span>{row.girls.text}
                </span>
                {row.girls.note && (
                  <span class="block text-xs text-gray-600 mt-0.5">{row.girls.note}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</section>
